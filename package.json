{
  "name": "react-logo-soup",
  "version": "0.3.0",
  "description": "A tiny React library that makes logos look good together",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target browser --format esm --sourcemap=external --external react --external react-dom && bun build src/index.ts --outfile dist/index.cjs --target browser --format cjs --sourcemap=inline --external react --external react-dom && bun run build:types",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "generate:logos": "bun scripts/generate-test-logos.ts",
    "prepublishOnly": "bun run build",
    "test": "NODE_ENV=development bun test",
    "bench": "bun tests/bench/run.ts",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sanity-labs/react-logo-soup.git"
  },
  "homepage": "https://github.com/sanity-labs/react-logo-soup#readme",
  "bugs": {
    "url": "https://github.com/sanity-labs/react-logo-soup/issues"
  },
  "keywords": [
    "react",
    "logo",
    "normalize",
    "layout",
    "component"
  ],
  "license": "MIT",
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@happy-dom/global-registrator": "^16",
    "@napi-rs/canvas": "^0.1.90",
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/addon-links": "^10.2.8",
    "@storybook/react": "^10.2.8",
    "@storybook/react-vite": "^10.2.8",
    "@testing-library/react": "^16",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "storybook": "^10.2.8",
    "vite": "^5"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "typescript": "^5"
  }
}
