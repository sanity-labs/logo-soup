{
  "name": "@sanity-labs/logo-soup",
  "version": "1.1.0",
  "description": "A tiny framework-agnostic library that makes logos look good together",
  "type": "module",
  "sideEffects": false,
  "browserslist": "extends @sanity/browserslist-config",
  "exports": {
    ".": {
      "source": "./src/core/index.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./react": {
      "source": "./src/react/index.ts",
      "import": "./dist/react/index.js",
      "default": "./dist/react/index.js"
    },
    "./vue": {
      "source": "./src/vue/index.ts",
      "import": "./dist/vue/index.js",
      "default": "./dist/vue/index.js"
    },
    "./svelte": {
      "source": "./src/svelte/index.ts",
      "import": "./dist/svelte/index.js",
      "default": "./dist/svelte/index.js"
    },
    "./solid": {
      "source": "./src/solid/index.ts",
      "import": "./dist/solid/index.js",
      "default": "./dist/solid/index.js"
    },
    "./angular": {
      "source": "./src/angular/index.ts",
      "import": "./dist/angular/index.js",
      "default": "./dist/angular/index.js"
    },
    "./jquery": {
      "source": "./src/jquery/index.ts",
      "import": "./dist/jquery/index.js",
      "default": "./dist/jquery/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/core/index.js",
        "default": "./dist/core/index.js"
      },
      "./react": {
        "import": "./dist/react/index.js",
        "default": "./dist/react/index.js"
      },
      "./vue": {
        "import": "./dist/vue/index.js",
        "default": "./dist/vue/index.js"
      },
      "./svelte": {
        "import": "./dist/svelte/index.js",
        "default": "./dist/svelte/index.js"
      },
      "./solid": {
        "import": "./dist/solid/index.js",
        "default": "./dist/solid/index.js"
      },
      "./angular": {
        "import": "./dist/angular/index.js",
        "default": "./dist/angular/index.js"
      },
      "./jquery": {
        "import": "./dist/jquery/index.js",
        "default": "./dist/jquery/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pkg-utils build --strict --check --clean",
    "release": "changeset publish",
    "generate:logos": "bun scripts/generate-test-logos.ts",
    "prepublishOnly": "bun run build",
    "test": "NODE_ENV=development bun test",
    "bench": "bun tests/bench/run.ts",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sanity-labs/logo-soup.git"
  },
  "homepage": "https://github.com/sanity-labs/logo-soup#readme",
  "bugs": {
    "url": "https://github.com/sanity-labs/logo-soup/issues"
  },
  "keywords": [
    "logo",
    "normalize",
    "layout",
    "component",
    "react",
    "vue",
    "svelte",
    "solid",
    "angular",
    "framework-agnostic"
  ],
  "license": "MIT",
  "devDependencies": {
    "@angular/core": "^19",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@chromatic-com/storybook": "^5.0.1",
    "@happy-dom/global-registrator": "^16",
    "@napi-rs/canvas": "^0.1.90",
    "@sanity/browserslist-config": "^1.0.5",
    "@sanity/pkg-utils": "^10.4.8",
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/addon-links": "^10.2.8",
    "@storybook/react": "^10.2.8",
    "@storybook/react-vite": "^10.2.8",
    "@testing-library/react": "^16",
    "@types/bun": "latest",
    "@types/jquery": "^4.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jquery": "4",
    "react": "^19",
    "react-dom": "^19",
    "solid-js": "^1.9",
    "storybook": "^10.2.8",
    "svelte": "^5",
    "vite": "^5",
    "vue": "^3.5"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "vue": "^3.5",
    "svelte": "^5",
    "solid-js": "^1.9",
    "@angular/core": "^19 || ^20 || ^21",
    "jquery": "^4",
    "typescript": "^5"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "jquery": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  }
}
